#!/usr/bin/env bash
# Launch wrapper so DuckDB's vgi extension can spawn this TypeScript worker via a
# plain filesystem LOCATION:
#   ATTACH 'files' AS files (TYPE vgi, LOCATION '/path/to/vgi-azure-files/bin/vgi-azure-files-worker',
#          TENANT_ID '…', CLIENT_ID '…', CLIENT_SECRET '…');
# VGI_BUN_CONDITIONS (e.g. "worker") selects the flechette Arrow backend when set.
exec bun ${VGI_BUN_CONDITIONS:+--conditions "$VGI_BUN_CONDITIONS"} run "$(dirname "$0")/../src/worker.ts" "$@"
